---
// کامپوننت ورود/خروج (Google با redirect + GitHub با popup)
---

<div id="user-login-wrapper" class="fixed top-13 left-0 z-50 m-4">
  <div class="bg-white/90 dark:bg-gray-800/90 backdrop-blur-md p-3 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 flex flex-col items-end gap-2">
    <p class="text-xs text-gray-600 dark:text-gray-300 mb-1">🔭 به جمع کاوشگران علم بپیوندید!</p>
    <div class="flex items-center gap-2">
      <button id="google-signin-btn" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-full text-sm font-semibold shadow transition">Google</button>
      <button id="github-signin-btn" class="bg-gray-700 hover:bg-gray-800 text-white px-4 py-2 rounded-full text-sm font-semibold shadow transition">GitHub</button>
      <button id="logout-btn" class="hidden bg-rose-500 hover:bg-rose-600 text-white px-4 py-2 rounded-full text-sm font-semibold shadow transition">خروج</button>
      <span id="user-name" class="text-sm text-gray-800 dark:text-gray-200 mr-2"></span>
    </div>
  </div>
</div>

<script>
  (function() {
    function waitForAuth(cb) {
      if (window.firebaseAuth) {
        cb(window.firebaseAuth);
      } else {
        setTimeout(() => waitForAuth(cb), 150);
      }
    }

    waitForAuth(function(auth) {
      import("https://www.gstatic.com/firebasejs/12.14.0/firebase-auth.js")
        .then(({ GoogleAuthProvider, signInWithRedirect, getRedirectResult, GithubAuthProvider, signInWithPopup, signOut, onAuthStateChanged }) => {
          
          const googleProvider = new GoogleAuthProvider();
          const githubProvider = new GithubAuthProvider();

          // Google: استفاده از redirect به جای popup
          document.getElementById('google-signin-btn').addEventListener('click', () => {
            signInWithRedirect(auth, googleProvider);
          });

          // GitHub همچنان popup (چون معمولاً در ایران پایدار است)
          document.getElementById('github-signin-btn').addEventListener('click', () => {
            signInWithPopup(auth, githubProvider).catch(err => alert('خطا: ' + err.message));
          });

          // پس از برگشت از redirect، نتیجه را دریافت می‌کنیم
          getRedirectResult(auth)
            .then(result => {
              if (result) {
                // ورود موفق—نیازی به کار اضافه نیست (onAuthStateChanged فراخوانی می‌شود)
              }
            })
            .catch(err => alert('خطا در بازگشت: ' + err.message));

          document.getElementById('logout-btn').addEventListener('click', () => {
            signOut(auth);
          });

          onAuthStateChanged(auth, (user) => {
            const googleBtn = document.getElementById('google-signin-btn');
            const githubBtn = document.getElementById('github-signin-btn');
            const logoutBtn = document.getElementById('logout-btn');
            const userName = document.getElementById('user-name');
            if (user) {
              googleBtn.classList.add('hidden');
              githubBtn.classList.add('hidden');
              logoutBtn.classList.remove('hidden');
              userName.textContent = user.displayName || user.email;
            } else {
              googleBtn.classList.remove('hidden');
              githubBtn.classList.remove('hidden');
              logoutBtn.classList.add('hidden');
              userName.textContent = '';
            }
          });

        });
    });
  })();
</script>
