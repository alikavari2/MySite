---
// ورود با گوگل + اتصال به Firebase Auth برای نظرات
---

<div id="user-login-wrapper" class="fixed top-12 left-0 z-50 m-4">
  <div class="bg-white/90 dark:bg-gray-800/90 backdrop-blur-md p-3 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 flex flex-col items-end gap-2">
    <p class="text-xs text-gray-600 dark:text-gray-300 mb-1">🔭 به جمع کاوشگران علم بپیوندید!</p>
    <div class="flex items-center gap-2">
      <a id="google-signin-btn" href="#" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-full text-sm font-semibold shadow transition">ورود با گوگل</a>
      <button id="logout-btn" class="hidden bg-rose-500 hover:bg-rose-600 text-white px-4 py-2 rounded-full text-sm font-semibold shadow transition">خروج</button>
      <span id="user-name" class="text-sm text-gray-800 dark:text-gray-200 mr-2"></span>
    </div>
  </div>
</div>

<script>
  (function() {
    const GOOGLE_CLIENT_ID = "833755635104-co6bhmbll4gkmu9jv5chcqs08acf2mc4.apps.googleusercontent.com";
    const REDIRECT_URI = "https://alikavari.ir";

    function buildGoogleAuthUrl() {
      const params = new URLSearchParams({
        client_id: GOOGLE_CLIENT_ID,
        redirect_uri: REDIRECT_URI,
        response_type: "id_token token",
        scope: "openid email profile",
        nonce: Math.random().toString(36).substring(2, 15),
        prompt: "select_account",
      });
      return "https://accounts.google.com/o/oauth2/v2/auth?" + params.toString();
    }

    function checkAuthResponse() {
      const hash = window.location.hash.substring(1);
      if (!hash) return null;
      const params = new URLSearchParams(hash);
      const idToken = params.get("id_token");
      if (idToken) {
        sessionStorage.setItem("google_id_token", idToken);
        history.replaceState(null, "", window.location.pathname + window.location.search);
        // ورود به Firebase Auth با توکن گوگل
        if (window.firebaseAuth) {
          import("https://www.gstatic.com/firebasejs/12.14.0/firebase-auth.js")
            .then(({ GoogleAuthProvider, signInWithCredential }) => {
              const credential = GoogleAuthProvider.credential(idToken);
              return signInWithCredential(window.firebaseAuth, credential);
            })
            .catch(e => console.error("Firebase auth sign-in failed:", e));
        }
        return idToken;
      }
      return null;
    }

    function parseJWT(token) {
      try {
        const payload = JSON.parse(atob(token.split(".")[1]));
        return { name: payload.name, email: payload.email };
      } catch (e) {
        return null;
      }
    }

    function setUser(user) {
      const loginLink = document.getElementById("google-signin-btn");
      const logoutBtn = document.getElementById("logout-btn");
      const userName = document.getElementById("user-name");
      if (user) {
        loginLink.classList.add("hidden");
        logoutBtn.classList.remove("hidden");
        userName.textContent = user.name || user.email;
      } else {
        loginLink.classList.remove("hidden");
        logoutBtn.classList.add("hidden");
        userName.textContent = "";
      }
    }

    function init() {
      document.getElementById("google-signin-btn").href = buildGoogleAuthUrl();

      const idToken = checkAuthResponse();
      if (idToken) {
        const user = parseJWT(idToken);
        if (user) {
          sessionStorage.setItem("user", JSON.stringify(user));
          setUser(user);
        }
      } else {
        const storedUser = sessionStorage.getItem("user");
        if (storedUser) {
          setUser(JSON.parse(storedUser));
        }
      }

      document.getElementById("logout-btn").addEventListener("click", function() {
        sessionStorage.removeItem("google_id_token");
        sessionStorage.removeItem("user");
        // خروج از Firebase Auth هم
        if (window.firebaseAuth) {
          window.firebaseAuth.signOut();
        }
        setUser(null);
      });
    }

    init();
  })();
</script>
