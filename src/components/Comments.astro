---
export interface Props {
  postSlug: string;
}
const { postSlug } = Astro.props;
---

<div id="comments-section" class="mx-auto px-6 sm:px-6 max-w-3xl mt-12 border-t pt-8 dark:border-gray-700">
  <h3 class="text-xl font-bold mb-4">💬 نظرات</h3>
  <div id="comments-list" class="space-y-4 mb-6"></div>

  <div id="comment-form" class="hidden">
    <textarea id="comment-text" rows="3" class="w-full p-2 rounded border dark:bg-gray-800 dark:border-gray-600" placeholder="نظر شما..."></textarea>
    <button id="add-comment-btn" class="mt-2 bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded">ارسال نظر</button>
  </div>
  <p id="login-prompt" class="text-gray-500">برای ارسال نظر، لطفاً وارد شوید.</p>
</div>

<script>
  import { collection, addDoc, query, orderBy, onSnapshot, serverTimestamp } from "https://www.gstatic.com/firebasejs/12.14.0/firebase-firestore.js";

  const db = window.firestoreDB;
  const auth = window.firebaseAuth;
  const postId = "{{postSlug}}";

  const listEl = document.getElementById('comments-list');
  const formEl = document.getElementById('comment-form');
  const textEl = document.getElementById('comment-text');
  const addBtn = document.getElementById('add-comment-btn');
  const loginPrompt = document.getElementById('login-prompt');

  auth.onAuthStateChanged(user => {
    if (user) {
      formEl.classList.remove('hidden');
      loginPrompt.classList.add('hidden');
    } else {
      formEl.classList.add('hidden');
      loginPrompt.classList.remove('hidden');
    }
  });

  addBtn.addEventListener('click', async () => {
    const user = auth.currentUser;
    if (!user) return;
    const text = textEl.value.trim();
    if (!text) return;
    await addDoc(collection(db, 'comments'), {
      postId: postId,
      text: text,
      author: user.displayName || user.email,
      createdAt: serverTimestamp()
    });
    textEl.value = '';
  });

  const q = query(collection(db, 'comments'), orderBy('createdAt', 'asc'));
  onSnapshot(q, snapshot => {
    listEl.innerHTML = '';
    snapshot.forEach(doc => {
      const data = doc.data();
      if (data.postId !== postId) return;
      const div = document.createElement('div');
      div.className = 'border-b pb-2';
      div.innerHTML = `<strong>${data.author}</strong>: ${data.text}`;
      listEl.appendChild(div);
    });
  });
</script>
