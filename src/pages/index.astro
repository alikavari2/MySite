---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';
import { getPermalink } from '~/utils/permalinks';

const categoryMap: Record<string, string> = {
  physics: 'فیزیک',
  chemistry: 'شیمی',
  biology: 'زیست‌شناسی',
  'earth-astronomy': 'زمین و نجوم',
  'computer-science': 'علوم کامپیوتر',
  metaphysics: 'علوم فرامادی',
};

// دریافت همۀ پست‌ها و حذف پیش‌نویس‌ها
const allPosts = await getCollection('post');
const publishedPosts = allPosts.filter(p => !p.data.draft);

// تابع شمارش پست‌های منتشرشده در هر دسته (trim برای حذف فاصله‌های اضافه)
const getCategoryCount = (slug: string) =>
  publishedPosts.filter(p => p.data.category?.trim() === slug).length;

// استخراج slug از id (حذف مسیر و پسوند، اما نگه‌داشتن تاریخ)
const getSlug = (id: string) => {
  // id به صورت src/data/post/2026-06-15-pst-chharm.md است
  return id.replace(/^src\/data\/post\//, '').replace(/\.md$/, '');
};

// گرفتن ۳ پست آخر
const latestPosts = [...publishedPosts]
  .sort((a, b) => {
    const dateA = new Date(a.data.publishDate);
    const dateB = new Date(b.data.publishDate);
    const timeA = a.data.publishTime || '12:00';
    const timeB = b.data.publishTime || '12:00';
    const fullA = new Date(`${dateA.toISOString().split('T')[0]}T${timeA}:00`);
    const fullB = new Date(`${dateB.toISOString().split('T')[0]}T${timeB}:00`);
    return fullB.getTime() - fullA.getTime();
  })
  .slice(0, 3);
---

<Layout metadata={{ title: 'آزمایشگاه دیجیتال علی کواری' }}>
  <Header {...headerData} isSticky showRssFeed showToggleTheme />

  <main class="min-h-screen bg-gradient-to-b from-gray-900 via-gray-800 to-black text-white" dir="rtl">
    <!-- Hero Section -->
    <section class="text-center pt-20 pb-12 px-4">
      <h1 class="text-5xl md:text-7xl font-extrabold mb-4 bg-clip-text text-transparent bg-gradient-to-l from-blue-400 to-purple-600">
        به آزمایشگاه دیجیتال من خوش آمدید
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto">
        جایی که اسرار فیزیک، شیمی، زیست، نجوم، کامپیوتر و فراتر از آن را با هم کاوش می‌کنیم.
        <br/>پاینده باشید و کنجکاو! 🚀
      </p>
    </section>

    <!-- Science Stations Grid -->
    <section class="max-w-7xl mx-auto px-4 pb-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- فیزیک -->
        <a href="/category/physics" class="group block bg-white/5 backdrop-blur-sm rounded-3xl p-6 border border-white/10 hover:bg-white/10 hover:scale-105 transition-all duration-300">
          <div class="text-6xl mb-4">⚛️</div>
          <h2 class="text-2xl font-bold mb-2 group-hover:text-blue-400">فیزیک</h2>
          <p class="text-gray-400 mb-4">از ذرات زیراتمی تا کهکشان‌ها</p>
          <div class="flex justify-between items-center">
            <span class="text-blue-400 group-hover:underline">کاوش کنید →</span>
            <span class="text-xs bg-white/10 px-2 py-1 rounded-full">{getCategoryCount('physics')} پست</span>
          </div>
        </a>

        <!-- شیمی -->
        <a href="/category/chemistry" class="group block bg-white/5 backdrop-blur-sm rounded-3xl p-6 border border-white/10 hover:bg-white/10 hover:scale-105 transition-all duration-300">
          <div class="text-6xl mb-4">🧪</div>
          <h2 class="text-2xl font-bold mb-2 group-hover:text-green-400">شیمی</h2>
          <p class="text-gray-400 mb-4">دنیای مولکول‌ها و واکنش‌ها</p>
          <div class="flex justify-between items-center">
            <span class="text-green-400 group-hover:underline">کاوش کنید →</span>
            <span class="text-xs bg-white/10 px-2 py-1 rounded-full">{getCategoryCount('chemistry')} پست</span>
          </div>
        </a>

        <!-- زیست‌شناسی -->
        <a href="/category/biology" class="group block bg-white/5 backdrop-blur-sm rounded-3xl p-6 border border-white/10 hover:bg-white/10 hover:scale-105 transition-all duration-300">
          <div class="text-6xl mb-4">🧬</div>
          <h2 class="text-2xl font-bold mb-2 group-hover:text-emerald-400">زیست‌شناسی</h2>
          <p class="text-gray-400 mb-4">رمز و راز حیات</p>
          <div class="flex justify-between items-center">
            <span class="text-emerald-400 group-hover:underline">کاوش کنید →</span>
            <span class="text-xs bg-white/10 px-2 py-1 rounded-full">{getCategoryCount('biology')} پست</span>
          </div>
        </a>

        <!-- نجوم -->
        <a href="/category/earth-astronomy" class="group block bg-white/5 backdrop-blur-sm rounded-3xl p-6 border border-white/10 hover:bg-white/10 hover:scale-105 transition-all duration-300">
          <div class="text-6xl mb-4">🌍</div>
          <h2 class="text-2xl font-bold mb-2 group-hover:text-yellow-400">زمین و نجوم</h2>
          <p class="text-gray-400 mb-4">از اعماق زمین تا کرانه‌های کیهان</p>
          <div class="flex justify-between items-center">
            <span class="text-yellow-400 group-hover:underline">کاوش کنید →</span>
            <span class="text-xs bg-white/10 px-2 py-1 rounded-full">{getCategoryCount('earth-astronomy')} پست</span>
          </div>
        </a>

        <!-- کامپیوتر -->
        <a href="/category/computer-science" class="group block bg-white/5 backdrop-blur-sm rounded-3xl p-6 border border-white/10 hover:bg-white/10 hover:scale-105 transition-all duration-300">
          <div class="text-6xl mb-4">💻</div>
          <h2 class="text-2xl font-bold mb-2 group-hover:text-cyan-400">علوم کامپیوتر</h2>
          <p class="text-gray-400 mb-4">منطق، کد و دنیای دیجیتال</p>
          <div class="flex justify-between items-center">
            <span class="text-cyan-400 group-hover:underline">کاوش کنید →</span>
            <span class="text-xs bg-white/10 px-2 py-1 rounded-full">{getCategoryCount('computer-science')} پست</span>
          </div>
        </a>

        <!-- علوم فرامادی -->
        <a href="/category/metaphysics" class="group block bg-white/5 backdrop-blur-sm rounded-3xl p-6 border border-white/10 hover:bg-white/10 hover:scale-105 transition-all duration-300">
          <div class="text-6xl mb-4">🔮</div>
          <h2 class="text-2xl font-bold mb-2 group-hover:text-purple-400">علوم فرامادی</h2>
          <p class="text-gray-400 mb-4">مرزهای ناشناختهٔ دانش</p>
          <div class="flex justify-between items-center">
            <span class="text-purple-400 group-hover:underline">کاوش کنید →</span>
            <span class="text-xs bg-white/10 px-2 py-1 rounded-full">{getCategoryCount('metaphysics')} پست</span>
          </div>
        </a>
      </div>
    </section>

    <!-- جدیدترین نوشته‌ها -->
    {
      latestPosts.length > 0 && (
        <section class="max-w-7xl mx-auto px-4 pb-20">
          <h2 class="text-3xl font-bold text-center mb-12">📝 تازه‌ترین نوشته‌ها</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {latestPosts.map((post) => {
              const slug = getSlug(post.id); // نگه‌داشتن تاریخ در slug
              const permalink = `/blog/${slug}/`;
              return (
                <a href={permalink} class="block bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:bg-white/10 hover:scale-105 transition-all duration-300">
                  <h3 class="text-lg font-semibold mb-2">{post.data.title}</h3>
                  <p class="text-gray-400 text-sm mb-3">{post.data.excerpt?.slice(0, 80)}...</p>
                  <div class="flex justify-between text-xs text-gray-500">
                    <span>{new Date(post.data.publishDate).toLocaleDateString('fa-IR')}</span>
                    <span>{categoryMap[post.data.category?.trim()] || post.data.category}</span>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )
    }
  </main>

  <Footer {...footerData} />
</Layout>
